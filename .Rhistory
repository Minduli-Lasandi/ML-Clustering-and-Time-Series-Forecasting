#Loadng required libraries
library(readxl)
library(neuralnet)
library(ggplot2)
# Load the Excel file with data
data <- read_excel("ExchangeUSD_Dataset.xlsx")
# Extract the 3rd column from dataset
extracted_data <- data[[3]]
#Extract the data for training and testing
train_data <- extracted_data[1:400]
test_data <- extracted_data[401:500]
print(test_data)
# Define a function to create time-delayed input vectors
create_input_vectors <- function(data, delay) {
inputs <- matrix(NA, nrow = length(data) - delay, ncol = delay)
for (i in 1:delay) {
inputs[, i] <- data[i:(length(data) - delay + i - 1)]
}
inputs
}
# Set the maximum delay (up to t-4 level)
max_delay <- 4
# Create input vectors for training and testing
train_inputs <- create_input_vectors(train_data, max_delay)
test_inputs <- create_input_vectors(test_data, max_delay)
print(train_inputs)
# Create output vectors for training and testing
train_outputs <- train_data[(max_delay + 1):length(train_data)]
test_outputs <- test_data[(max_delay + 1):length(test_data)]
print(train_outputs)
# Scale the input and output data
scaled_train_inputs <- scale(train_inputs)
scaled_test_inputs <- scale(test_inputs)
scaled_train_outputs <- scale(train_outputs)
scaled_test_outputs <- scale(test_outputs)
print(scaled_train_inputs)
print(scaled_train_outputs)
# Print scaled input and output matrices
for (t in 1:max_delay) {
cat("Time Delay t-", t, ":\n")
cat("Scaled Training Input Matrix:\n")
print(scaled_train_inputs[, 1:t])
cat("Scaled Training Output Vector:\n")
print(scaled_train_outputs[-(1:t)])
cat("Scaled Testing Input Matrix:\n")
print(scaled_test_inputs[, 1:t])
cat("Scaled Testing Output Vector:\n")
print(scaled_test_outputs[-(1:t)])
}
# Convert scaled train inputs matrix to vector
scaled_train_inputs_vector <- c(scaled_train_inputs)
# Convert scaled test inputs matrix to vector
scaled_test_inputs_vector <- c(scaled_test_inputs)
scaled_train_outputs_vector <- c(scaled_train_outputs)
scaled_test_outputs_vector <- c(scaled_test_outputs)
# Define MLP models with different configurations
models <- list(
# Model 1
list(
model = neuralnet(
scaled_train_outputs ~ scaled_train_inputs_vector,
data = data.frame(scaled_train_inputs_vector, scaled_train_outputs),
hidden = c(10,5),
linear.output = FALSE
)
),
# Model 2
list(
model = neuralnet(
scaled_train_outputs ~ scaled_train_inputs_vector,
data = data.frame(scaled_train_inputs_vector, scaled_train_outputs),
hidden = c(20),
linear.output = FALSE
)
),
# Model 3
list(
model = neuralnet(
scaled_train_outputs ~ scaled_train_inputs_vector,
data = data.frame(scaled_train_inputs_vector, scaled_train_outputs),
hidden = c(10, 5),
linear.output = FALSE
)
),
# Model 4
list(
model = neuralnet(
scaled_train_outputs ~ scaled_train_inputs_vector,
data = data.frame(scaled_train_inputs_vector, scaled_train_outputs),
hidden = c(15),
linear.output = FALSE
)
),
# Model 5
list(
model = neuralnet(
scaled_train_outputs ~ scaled_train_inputs_vector,
data = data.frame(scaled_train_inputs_vector, scaled_train_outputs),
hidden = c(20),
linear.output = FALSE
)
),
# Model 6
list(
model = neuralnet(
scaled_train_outputs ~ scaled_train_inputs_vector,
data = data.frame(scaled_train_inputs_vector, scaled_train_outputs),
hidden = c(15, 5),
linear.output = FALSE
)
),
# Model 7
list(
model = neuralnet(
scaled_train_outputs ~ scaled_train_inputs_vector,
data = data.frame(scaled_train_inputs_vector, scaled_train_outputs),
hidden = c(10),
linear.output = FALSE
)
),
# Model 8
list(
model = neuralnet(
scaled_train_outputs ~ scaled_train_inputs_vector,
data = data.frame(scaled_train_inputs_vector, scaled_train_outputs),
hidden = c(20,10),
linear.output = FALSE
)
),
# Model 9
list(
model = neuralnet(
scaled_train_outputs ~ scaled_train_inputs_vector,
data = data.frame(scaled_train_inputs_vector, scaled_train_outputs),
hidden = c(5),
linear.output = FALSE
)
),
# Model 10
list(
model = neuralnet(
scaled_train_outputs ~ scaled_train_inputs_vector,
data = data.frame(scaled_train_inputs_vector, scaled_train_outputs),
hidden = c(7,10),
linear.output = FALSE
)
),
# Model 11
list(
model = neuralnet(
scaled_train_outputs ~ scaled_train_inputs_vector,
data = data.frame(scaled_train_inputs_vector, scaled_train_outputs),
hidden = c(20),
linear.output = FALSE
)
),
# Model 12
list(
model = neuralnet(
scaled_train_outputs ~ scaled_train_inputs_vector,
data = data.frame(scaled_train_inputs_vector, scaled_train_outputs),
hidden = c(10, 20),
linear.output = FALSE
)
)
)
# Loop through each model and evaluate
for (i in 1:length(models)) {
model <- models[[i]]$model
# Make predictions using the model
predictions <- predict(model, data.frame(scaled_test_inputs_vector))
# Inverse scale the predictions and actual test outputs
scaled_predictions <- predictions * sd(test_outputs) + mean(test_outputs)
scaled_actuals <- scaled_test_outputs_vector * sd(test_outputs) + mean(test_outputs)
# Calculate evaluation metrics
RMSE <- sqrt(mean((scaled_predictions - scaled_actuals)^2))
MAE <- mean(abs(scaled_predictions - scaled_actuals))
MAPE <- mean(abs((scaled_predictions - scaled_actuals) / scaled_actuals)) * 100
sMAPE <- mean(2 * abs(scaled_predictions - scaled_actuals) / (abs(scaled_predictions) + abs(scaled_actuals))) * 100
# Store results in the results dataframe
results[i, "RMSE"] <- RMSE
results[i, "MAE"] <- MAE
results[i, "MAPE"] <- MAPE
results[i, "sMAPE"] <- sMAPE
# Print the results
cat("RMSE:", RMSE, "\n")
cat("MAE:", MAE, "\n")
cat("MAPE:", MAPE, "%\n")
cat("sMAPE:", sMAPE, "%\n\n")
}
# Evaluate each model
results <- data.frame(
RMSE = numeric(length(models)),
MAE = numeric(length(models)),
MAPE = numeric(length(models)),
sMAPE = numeric(length(models))
)
# Loop through each model and evaluate
for (i in 1:length(models)) {
model <- models[[i]]$model
# Make predictions using the model
predictions <- predict(model, data.frame(scaled_test_inputs_vector))
# Inverse scale the predictions and actual test outputs
scaled_predictions <- predictions * sd(test_outputs) + mean(test_outputs)
scaled_actuals <- scaled_test_outputs_vector * sd(test_outputs) + mean(test_outputs)
# Calculate evaluation metrics
RMSE <- sqrt(mean((scaled_predictions - scaled_actuals)^2))
MAE <- mean(abs(scaled_predictions - scaled_actuals))
MAPE <- mean(abs((scaled_predictions - scaled_actuals) / scaled_actuals)) * 100
sMAPE <- mean(2 * abs(scaled_predictions - scaled_actuals) / (abs(scaled_predictions) + abs(scaled_actuals))) * 100
# Store results in the results dataframe
results[i, "RMSE"] <- RMSE
results[i, "MAE"] <- MAE
results[i, "MAPE"] <- MAPE
results[i, "sMAPE"] <- sMAPE
# Print the results
cat("RMSE:", RMSE, "\n")
cat("MAE:", MAE, "\n")
cat("MAPE:", MAPE, "%\n")
cat("sMAPE:", sMAPE, "%\n\n")
}
# Print the final results dataframe
print(results)
#Plotting the graph for the best model
best_model <- models[[8]]$model
# Make predictions using the best model
predictions <- predict(best_model, data.frame(scaled_test_inputs_vector))
# Inverse scale the predictions and actual test outputs
inv_scaled_predictions <- predictions * sd(test_outputs) + mean(test_outputs)
inv_scaled_actuals <- scaled_test_outputs_vector * sd(test_outputs) + mean(test_outputs)
# Create a dataframe for plotting
plot_data <- data.frame(Desired = inv_scaled_actuals, Predicted = inv_scaled_predictions)
# Plot the predicted output vs. desired output
ggplot(plot_data, aes(x = Desired, y = Predicted)) +
geom_point(color = "blue") +
geom_abline(intercept = 0, slope = 1, linetype = "dashed", color = "red") +
labs(x = "Desired Output", y = "Predicted Output", title = "MLP Network: Predicted vs. Desired Output") +
theme_minimal()
#Plotting the graph for the best model
best_model <- models[[2]]$model
# Make predictions using the best model
predictions <- predict(best_model, data.frame(scaled_test_inputs_vector))
